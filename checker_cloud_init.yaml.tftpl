#cloud-config
bootcmd:
  - [ sh, -c, 'for i in 1 2 3 4 5 6; do apt-get update && exit 0; sleep 15; done; exit 1' ]
package_update: false
package_upgrade: false
packages:
  - openssh-server
  - python3
  - python3-pip
  - python3-venv
  - git
  - build-essential
  - libpq-dev
  - curl
  - netcat-openbsd

ssh_authorized_keys:
  - ${admin_pubkey}

runcmd:
  - [ systemctl, enable, --now, ssh ]
